WEB_ORIGIN=http://localhost:3000 # Default: http://localhost:3000, for allow all origins use '*'
SOCKET_URL=http://localhost:3001 # Default: http://localhost:3001
GOOGLE_CLIENT_ID= # Optional: Google OAuth Client ID for manager sign-in
HUGGINGFACE_TOKEN= # Required for AI quiz drafting and image generation in the studio
HUGGINGFACE_TEXT_MODEL= # Optional: specific text model for quiz drafting; leave empty to auto-select a supported live model
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell # Optional: image model used for generated quiz images
